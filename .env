# Copy file này thành ".env" và đổi giá trị cho phù hợp.
# .env KHÔNG commit lên git.

# ----- Database -----
DB_NAME=booking
DB_USER=booking
DB_PASSWORD=booking_pwd

# ----- RabbitMQ -----
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ----- JWT -----
# QUAN TRỌNG: đổi secret này trong production. Phải >= 32 ký tự.
JWT_SECRET=keykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykeykey
JWT_EXPIRATION_MS=3600000
